<Window x:Class="LocalityGuiClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LocalityGuiClient"
        mc:Ignorable="d"
        Title="Localities GUI Client" Height="500" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="REST base URL:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox x:Name="BaseUrlTextBox" Width="260" Text="https://localhost:49105" />
            <Button x:Name="LoadButton" Content="Загрузить локации" Margin="8,0,0,0" Padding="8,2"
                    Click="LoadButton_OnClick" />
        </StackPanel>

        <DataGrid x:Name="LocalitiesGrid"
                  Grid.Row="1" Grid.Column="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0,0,8,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding id}" Width="50" />
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="100" />
                <DataGridTextColumn Header="Население (тыс.)" Binding="{Binding NumberResidantsTh}" Width="140" />
                <DataGridTextColumn Header="Бюджет (млрд)" Binding="{Binding BudgetMlrd}" Width="120" />
                <DataGridTextColumn Header="Площадь (км²)" Binding="{Binding SquareKm}" Width="120" />
                <DataGridTextColumn Header="Мэр" Binding="{Binding Mayor}" Width="160" />
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="1" Grid.Column="1" Header="Детали" Padding="8">
            <StackPanel>
                <TextBlock Text="Название:" FontWeight="Bold" />
                <TextBlock x:Name="NameText" Margin="0,0,0,6" />

                <TextBlock Text="Тип:" FontWeight="Bold" />
                <TextBlock x:Name="TypeText" Margin="0,0,0,6" />

                <TextBlock Text="Население (тыс.):" FontWeight="Bold" />
                <TextBlock x:Name="ResidantsText" Margin="0,0,0,6" />

                <TextBlock Text="Бюджет (млрд):" FontWeight="Bold" />
                <TextBlock x:Name="BudgetText" Margin="0,0,0,6" />

                <TextBlock Text="Площадь (км²):" FontWeight="Bold" />
                <TextBlock x:Name="SquareText" Margin="0,0,0,6" />

                <TextBlock Text="Мэр:" FontWeight="Bold" />
                <TextBlock x:Name="MayorText" Margin="0,0,0,6" />
            </StackPanel>
        </GroupBox>

        <StatusBar Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готово" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
